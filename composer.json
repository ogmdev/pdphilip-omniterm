{
    "name": "pdphilip/omniterm",
    "description": "This is my package OmniTerm",
    "keywords": [
        "PDPhilip",
        "laravel",
        "omniterm"
    ],
    "homepage": "https://github.com/pdphilip/omniterm",
    "license": "MIT",
    "authors": [
        {
            "name": "David Philip",
            "email": "pd.philip@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "laravel/prompts": "^0.2||^0.3",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/console": "^7.0||^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^2.9||^3.0",
        "nunomaduro/collision": "^8.1.1",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "pestphp/pest": "^2.34||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.7||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.3||^3.0||^4.0",
        "phpstan/extension-installer": "^1.3||^2.0",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.3||^2.0"
    },
    "autoload": {
        "psr-4": {
            "OmniTerm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmniTerm\\Tests\\": "tests/",
            "OmniTerm\\Samples\\": "samples/Commands/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "types": "phpstan analyse --ansi --memory-limit=2G",
        "format": "pint -v",
        "test-coverage": "pest --coverage",
        "test:lint": "pint --test -v",
        "test:types": "@types",
        "test:unit": "pest --colors=always",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "test:l11": [
            "@composer update --with laravel/framework:^11.0 --prefer-stable --no-interaction --quiet",
            "@test:unit"
        ],
        "test:l12": [
            "@composer update --with laravel/framework:^12.0 --prefer-stable --no-interaction --quiet",
            "@test:unit"
        ],
        "test:l13": [
            "@composer update --with laravel/framework:^13.0 --prefer-stable --no-interaction --quiet",
            "@test:unit"
        ],
        "test:all": [
            "@test:l11",
            "@test:l12",
            "@test:l13"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OmniTerm\\OmniTermServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
